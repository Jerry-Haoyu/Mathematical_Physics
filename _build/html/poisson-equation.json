{"version":3,"kind":"Notebook","sha256":"e3aa20a704e0f05d40674af48965999d1d978000b299873cfb2972d9fe2b5e8f","slug":"poisson-equation","location":"/pde/elementary_methods/poisson_equation/poisson_equation.md","dependencies":[],"frontmatter":{"title":"Poisson Equation","kernelspec":{"name":"python3","display_name":"Python 3"},"content_includes_title":false,"authors":[{"id":"Haoyu Tang","name":"Haoyu Tang"}],"github":"https://github.com/Jerry-Haoyu/Mathematical_Physics","numbering":{"title":{"offset":2}},"source_url":"https://github.com/Jerry-Haoyu/Mathematical_Physics/blob/main/pde/elementary_methods/poisson_equation/poisson_equation.md","edit_url":"https://github.com/Jerry-Haoyu/Mathematical_Physics/edit/main/pde/elementary_methods/poisson_equation/poisson_equation.md","exports":[{"format":"md","filename":"poisson_equation.md","url":"/build/poisson_equation-f3332ed6a4602641249fe3ffa5803edb.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"Finite-Element Method(FEM)","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"OPtknkZBeB"}],"identifier":"finite-element-method-fem","label":"Finite-Element Method(FEM)","html_id":"finite-element-method-fem","implicit":true,"key":"GBsq80odby"},{"type":"heading","depth":3,"position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"text","value":"The Tent Function","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"Hbbrldj3Ks"}],"identifier":"the-tent-function","label":"The Tent Function","html_id":"the-tent-function","implicit":true,"key":"bLJEDmCzli"},{"type":"paragraph","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"text","value":"We consider the","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"SZXj8JULKX"}],"key":"YMsNPZQTap"}],"key":"KzxoD1i5eH"},{"type":"block","kind":"notebook-code","children":[{"type":"code","executable":true,"value":"import sys\nfrom pathlib import Path\nimport ipywidgets as wdgt\n\n# Calculates the absolute path to your 'src' directory\nsys.path.append(\"src\")\n\nfrom src.twoDPoissonFEM import twoDPoisson\n\nslider_resol = wdgt.FloatSlider(value=3.0, min=1.0, max=6.0, step=1.0)\nslider_pos = wdgt.FloatSlider(value=0.0, min=0.0, max=36.0, step=1.0)\n\ndef plot(resolution, position):\n    resolution, position = int(resolution), int(position)\n    solver = twoDPoisson(0,10.0,0,10.0,resolution=resolution, f=lambda x : x)\n    if position < resolution * resolution:\n        tent_basis = solver.get_basis(position)\n        fig, ax = solver.init_plot()\n        ax.scatter(solver.grid_x, solver.grid_y, color='red')\n        ax.plot_surface(solver.basis_x, solver.basis_y, tent_basis, cmap='coolwarm')\n\nwdgt.interactive(plot, resolution=slider_resol, position=slider_pos)","key":"RwEHeFV6Sy"},{"type":"outputs","id":"FJhUny1WnILuChhilF2bt","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"grid spacing is 1.6666666666666667\n"},"key":"wWrlscqIZ7"},{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"9201c08070087702d3ff303ea8684118","path":"/build/9201c08070087702d3ff303ea8684118.png"}}},"key":"N90khAXiLp"},{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":1,"metadata":{},"data":{"text/plain":{"content":"interactive(children=(FloatSlider(value=3.0, description='resolution', max=6.0, min=1.0, step=1.0), FloatSlide…","content_type":"text/plain"},"application/vnd.jupyter.widget-view+json":{"content":"{\"version_major\":2,\"version_minor\":0,\"model_id\":\"460323fe52c24abab97de0f7664ab21e\"}","content_type":"application/vnd.jupyter.widget-view+json"}}},"key":"nDZTlXNZCr"}],"key":"y5Am6ywaaD"}],"key":"UECivqBdau"}],"key":"lRybKuEdxr"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Wave Equation","url":"/wave-equation","group":"Elementary Methods"},"next":{"title":"Analytical Function","url":"/analytical-function","group":"Complex Variable"}}},"domain":"http://localhost:3000"}