{"version":3,"kind":"Notebook","sha256":"527866d970fbc20645dc78390d56022c98176b1b24aec9fced64ddef37536aa1","slug":"poisson-equation","location":"/pde/elementary_methods/poisson_equation/poisson_equation.md","dependencies":[],"frontmatter":{"title":"Poisson Equation","kernelspec":{"name":"python3","display_name":"Python 3"},"content_includes_title":false,"authors":[{"id":"Haoyu Tang","name":"Haoyu Tang"}],"github":"https://github.com/Jerry-Haoyu/Mathematical_Physics","numbering":{"title":{"offset":2}},"source_url":"https://github.com/Jerry-Haoyu/Mathematical_Physics/blob/main/pde/elementary_methods/poisson_equation/poisson_equation.md","edit_url":"https://github.com/Jerry-Haoyu/Mathematical_Physics/edit/main/pde/elementary_methods/poisson_equation/poisson_equation.md","exports":[{"format":"md","filename":"poisson_equation.md","url":"/poisson_equation-818db782a07e58b84e3101b54e8dfa44.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"Finite-Element Method(FEM)","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"qUIIjnYrqB"}],"identifier":"finite-element-method-fem","label":"Finite-Element Method(FEM)","html_id":"finite-element-method-fem","implicit":true,"key":"uxEO79NcF2"},{"type":"heading","depth":3,"position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"text","value":"The Tent Function","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"M9JGmZcYjl"}],"identifier":"the-tent-function","label":"The Tent Function","html_id":"the-tent-function","implicit":true,"key":"AB6vg5iYxq"}],"key":"aPxsuL3fyU"},{"type":"block","kind":"notebook-code","children":[{"type":"code","executable":true,"value":"import sys\nfrom pathlib import Path\nimport ipywidgets as wdgt\n\n# Calculates the absolute path to your 'src' directory\nsys.path.append(\"src\")\n\nfrom src.twoDPoissonFEM import twoDPoisson\n\nslider_resol = wdgt.FloatSlider(value=3.0, min=1.0, max=6.0, step=1.0)\nslider_pos = wdgt.FloatSlider(value=0.0, min=0.0, max=36.0, step=1.0)\n\ndef plot(resolution, position):\n    resolution, position = int(resolution), int(position)\n    solver = twoDPoisson(0,10.0,0,10.0,resolution=resolution, f=lambda x : x)\n    if position < resolution * resolution:\n        tent_basis = solver.get_basis(position)\n        fig, ax = solver.init_plot()\n        ax.scatter(solver.grid_x, solver.grid_y, color='red')\n        ax.plot_surface(solver.basis_x, solver.basis_y, tent_basis, cmap='coolwarm')\n\nwdgt.interactive(plot, resolution=slider_resol, position=slider_pos)","key":"WjnpxL5X9s"},{"type":"outputs","id":"84wBkKgP6eQqzGeY8f8Ht","children":[],"key":"T375fK7InN"}],"key":"PvldHIhEy2"}],"key":"PQaRun237x"},"references":{"cite":{"order":[],"data":{}}}}